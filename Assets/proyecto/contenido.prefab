  - {fileID: 3456486711656679460}
  - {fileID: 7656753007580910479}
  - {fileID: 6152922763019234415}
  - {fileID: 5312297470743150955}
  - {fileID: 180291249706962317}
  - {fileID: 4172666711348064657}
  - {fileID: 5965412104849602117}
  velocidad: 0.6
  velocidadGiro: 5
  camara: {fileID: 0}
  distanciaFrenteCamara: 2
  distanciaParaSentarse: 0.25
  nombreAnimal: Quetzal
  nombreCientifico: Pharomachrus mocinno
  panelAnimal: {fileID: 0}
  panelHabitat: {fileID: 0}
  anim: {fileID: 0}
  sonidoAnimal: {fileID: 8300000, guid: 6935661f0b9a94f4c9f390f7a0be8aa7, type: 3}
  audioSource: {fileID: 2255030095187465526}
  imagenHabitat: {fileID: 21300000, guid: 5490406935c714c4e90fbaa793749574, type: 3}
  textoHabitat: "<align=justified>\r\n\r\n<b>H\xE1bitat del quetzal</b>\r\n\r\nEl
    <i>Pharomachrus mocinno</i>, conocido como quetzal, habita principalmente en
    bosques h\xFAmedos y monta\xF1osos de Centroam\xE9rica, donde existen abundantes
    \xE1rboles altos y una gran diversidad de vegetaci\xF3n.\r\n\r\n<b>H\xE1bitats
    donde vive:</b>\r\n\r\n\u2022 Bosques nubosos.\r\n\u2022 Selvas monta\xF1osas
    h\xFAmedas.\r\n\u2022 Bosques tropicales de niebla.\r\n\u2022 Zonas con \xE1rboles
    altos y vegetaci\xF3n densa.\r\n\r\n<b>Caracter\xEDsticas de su h\xE1bitat:</b>\r\n\r\n\u2022
    Prefiere lugares frescos y h\xFAmedos.\r\n\u2022 Vive en \xE1rboles grandes donde
    puede anidar y alimentarse.\r\n\u2022 Habita principalmente en monta\xF1as y
    selvas elevadas.\r\n\r\n<b>Distribuci\xF3n:</b>\r\n\r\nEl quetzal se encuentra
    desde el sur de M\xE9xico hasta Panam\xE1. En M\xE9xico habita especialmente
    en estados como:\r\n\r\n\u2022 Chiapas.\r\n\u2022 Oaxaca.\r\n\r\n</align>"
  panelAmenazas: {fileID: 0}
  amenazaImagen1: {fileID: 21300000, guid: 4349fcf2efd3c7849966162f9cff7eba, type: 3}
  amenazaImagen2: {fileID: 21300000, guid: 1e0a78fac447a924d8b28159f14f3d4c, type: 3}
  amenazaImagen3: {fileID: 21300000, guid: 6712fd45b0514bb42be5940375d1503c, type: 3}
  amenazaTexto1: "P\xE9rdida de h\xE1bitat"
  amenazaTexto2: "Fragmentaci\xF3n del bosque"
  amenazaTexto3: "Expansi\xF3n agr\xEDcola y ganadera"
  amenazaInfoAdicional: "El quetzal depende mucho de los bosques nubosos conservados.
    Cuando estos bosques se talan o se transforman para agricultura, ganader\xEDa
    o construcciones, pierde zonas de alimentaci\xF3n, refugio y anidaci\xF3n. Adem\xE1s,
    la fragmentaci\xF3n del bosque separa a las poblaciones, dificultando que encuentre
    pareja y reduciendo su supervivencia. La p\xE9rdida y degradaci\xF3n del h\xE1bitat
    es considerada una de sus amenazas m\xE1s importantes"
  panelDatosInteresantes: {fileID: 0}
  datosImagen: {fileID: 21300000, guid: 00f6a979cebb91546957e310d404d9ac, type: 3}
  datoInteresante1: "<b> Cola extremadamente larga</b>   Los machos pueden desarrollar
    plumas en la cola que llegan a medir m\xE1s que todo su cuerpo, lo que los convierte
    en una de las aves m\xE1s llamativas de Am\xE9rica."
  datoInteresante2: "<b> Ave sagrada</b>   El quetzal fue considerado un ave sagrada
    por culturas mesoamericanas como los mayas y los mexicas. Sus plumas eran s\xEDmbolo
    de poder, libertad y riqueza."
  datoInteresante3: "<b> No vive bien en cautiverio</b>   El quetzal es un ave muy
    sensible al estr\xE9s y a los cambios en su entorno, por lo que suele sobrevivir
    mejor en libertad dentro de los bosques donde habita naturalmente. "
