--- !u!114 &171742665
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 171742662}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ea17594c86ae62244b25d932d7c22570, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::mover_margay
  puntos:
  - {fileID: 278207008}
  - {fileID: 390555588}
  - {fileID: 1526782956}
  - {fileID: 1695786987}
  - {fileID: 1575886006}
  - {fileID: 1908085173}
  - {fileID: 741950444}
  - {fileID: 1416469874}
  velocidad: 0.5
  velocidadGiro: 5
  camara: {fileID: 1862705309}
  distanciaFrenteCamara: 2
  distanciaParaSentarse: 0.25
  nombreAnimal: Tapir
  nombreCientifico: Tapirus bairdii
  panelAnimal: {fileID: 1424935241}
  panelHabitat: {fileID: 1633377707}
  anim: {fileID: 0}
  sonidoAnimal: {fileID: 8300000, guid: 8a07c196d87af3e4ca2cb0b530037c1b, type: 3}
  audioSource: {fileID: 1627283574}
  imagenHabitat: {fileID: 21300000, guid: 42f5873543b81a34ca6aaa9bb5a91b87, type: 3}
  textoHabitat: "<align=justified>\r\n\r\n<b>H\xE1bitat</b>\r\n\r\nEl tapir habita
    principalmente en selvas tropicales h\xFAmedas, bosques densos, bosques mes\xF3filos
    de monta\xF1a, zonas pantanosas y \xE1reas cercanas a r\xEDos, arroyos y lagunas.\r\n\r\n<b>Caracter\xEDsticas
    de su h\xE1bitat:</b>\r\n\r\n\u2022 Prefiere lugares con abundante vegetaci\xF3n
    y sombra.\r\n\u2022 Necesita acceso constante a fuentes de agua.\r\n\u2022 Utiliza
    la vegetaci\xF3n densa para esconderse y desplazarse con seguridad.\r\n\u2022
    Habita en ecosistemas h\xFAmedos y poco alterados por el ser humano.\r\n\r\n<b>Distribuci\xF3n:</b>\r\n\r\nEn
    M\xE9xico se encuentra principalmente en estados como:\r\n\r\n\u2022 Chiapas.\r\n\u2022
    Oaxaca.\r\n\u2022 Campeche.\r\n\u2022 Quintana Roo.\r\n\r\nTambi\xE9n se distribuye
    desde el sur de M\xE9xico hasta Centroam\xE9rica y el norte de Sudam\xE9rica.\r\n\r\n</align>"
  panelAmenazas: {fileID: 503415807}
  amenazaImagen1: {fileID: 21300000, guid: 4349fcf2efd3c7849966162f9cff7eba, type: 3}
  amenazaImagen2: {fileID: 21300000, guid: 6712fd45b0514bb42be5940375d1503c, type: 3}
  amenazaImagen3: {fileID: 0}
  amenazaTexto1: "P\xE9rdida de h\xE1bitat"
  amenazaTexto2: "Expansi\xF3n agr\xEDcola y ganadera"
  amenazaTexto3: "Cacer\xEDa"
  amenazaInfoAdicional: "El tapir enfrenta problemas por la p\xE9rdida de h\xE1bitat
    causada por la tala y destrucci\xF3n de selvas. Adem\xE1s, la expansi\xF3n agr\xEDcola
    y ganadera reduce las zonas donde puede alimentarse y desplazarse. Tambi\xE9n
    es afectado por la cacer\xEDa ilegal, atropellamientos y la fragmentaci\xF3n
    del bosque, lo que dificulta que encuentre pareja y \xE1reas seguras para sobrevivir. "
  panelDatosInteresantes: {fileID: 563628025}
  datosImagen: {fileID: 21300000, guid: 053725ef0cc56e24b9735dfc90d7e702, type: 3}
  datoInteresante1: "<b>  Nariz flexible</b>   El tapir posee una peque\xF1a trompa
    flexible que utiliza para oler, tomar hojas y frutos, adem\xE1s de explorar su
    entorno y buscar alimento. "
  datoInteresante2: "<b>  Gran nadador</b>   Es un excelente nadador y suele usar
    r\xEDos, lagunas y zonas pantanosas para refrescarse, desplazarse y escapar de
    posibles depredadores."
  datoInteresante3: "<b>  Jardinero del bosque</b>   Al alimentarse de frutos y dispersar
    semillas a trav\xE9s de sus recorridos, el tapir ayuda a regenerar la selva y
    contribuye al equilibrio de los ecosistemas donde habita. "
